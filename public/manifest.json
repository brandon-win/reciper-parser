{
    "name": "Brandon's Recipe Parser",
    "description": "This extension is intended to be used to gather recipe metadata to a specific google doc.",
    "version": "1.0.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "index.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "oauth2": {
        "client_id": "425199555875-jglvqsa4k5i8rg13jma8urcqiqqrb5k5.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/userinfo.email",
            "https://www.googleapis.com/auth/spreadsheets",
            "https://www.googleapis.com/auth/drive.file"
        ]
    },
    "permissions": [
        "identity",
        "identity.email",
        "activeTab",
        "scripting"
    ]
}